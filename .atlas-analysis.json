{
  "projectType": "sdk-library",
  "projectName": "Atomemo Plugin SDK for JavaScript/TypeScript",
  "projectDescription": "A TypeScript SDK for developing Choiceform Atomemo plugins with WebSocket-based communication and type-safe feature registration.",
  "theme": "palm",
  "primaryColor": "#6366f1",
  "lightColor": "#818cf8",
  "darkColor": "#4f46e5",
