  },
  "keyFeatures": [
    "Type-safe plugin creation and management",
    "WebSocket-based real-time communication with Hub Server",
    "Built-in credential, tool, and model registration system",
    "Debug and release mode support",
    "Phoenix Channel integration for message handling",
    "Environment variable validation and configuration"
  ],
  "publicApiSurface": [
    "createPlugin(options)",
    "plugin.addCredential(credential)",
    "plugin.addTool(tool)",
    "plugin.addModel(model)",
    "plugin.run()",
    "createRegistry(plugin)",
    "registry.register(type, feature)",
    "registry.resolve(type, featureName)",
    "registry.serialize()",
    "createTransporter(options)",
    "transporter.connect(channelName)",
    "getEnv()"
  ]
}
